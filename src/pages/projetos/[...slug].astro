---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'projetos'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/
// Read more about dynamic routes and this `getStaticPaths` function in the Astro docs:
// https://docs.astro.build/en/guides/routing/#dynamic-routes
export async function getStaticPaths() {
	const projetos = await getCollection('projetos');
	return projetos.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href="/projetos"><Icon icon="arrow-left" /> Projetos</a>
					<Hero title={entry.data.title} tagline={entry.data.description} />
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content-container">
					{entry.data.img && <img src={entry.data.img} alt={entry.data.img_alt || ''} />}
					<div class="content">
						<Content />
					</div>
					
					<div class="project-footer">
						<div class="github-container">
							{entry.data.github ? (
								<a class="github-link" href={entry.data.github} target="_blank" rel="noopener noreferrer">
									<Icon icon="github-logo" size="1.2em" />
									Ver no GitHub
								</a>
							) : (
								<a class="github-link" href="#" target="_blank" rel="noopener noreferrer" title="Link não disponível">
									<Icon icon="github-logo" size="1.2em" />
									Ver no GitHub
								</a>
							)}
						</div>
						<div class="tags">
							{entry.data.tags.map((t) => <span class="tag">{t}</span>)}
						</div>
					</div>
				</div>
			</main>
		</div>
	</div>
</BaseLayout>

<style>
	header {
		padding-top: 5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	@media (min-width: 50em) {
		header {
			padding-top: 6rem;
		}
	}

	.back-link {
		display: none;
	}

	.content-container {
		max-width: 90ch; /* Wider than before to fit images/steps better */
		margin-inline: auto;
	}

	.content {
		width: 100%;
	}

	.project-footer {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		width: 100%;
		max-width: 90ch;
		margin-inline: auto;
		margin-top: 3rem;
		margin-bottom: 6rem;
		padding-top: 2rem;
		border-top: 1px solid var(--gray-800);
	}

	.github-container {
		display: flex;
		justify-content: center;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	.tag {
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		background-color: rgba(106, 90, 205, 0.1);
		color: #6a5acd;
		font-size: var(--text-sm);
		font-weight: 500;
	}

	:root.theme-light .tag {
		background-color: rgba(72, 61, 139, 0.1);
		color: #483d8b;
	}

	.github-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.75rem;
		background-color: #6a5acd;
		color: #ffffff;
		border-radius: 999px;
		border: none;
		text-decoration: none !important;
		font-weight: 600;
		font-size: var(--text-md);
		transition: all 0.2s ease;
		box-shadow: 0 4px 14px 0 rgba(106, 90, 205, 0.39);
	}

	:root.theme-light .github-link {
		background-color: #6a5acd;
		color: #ffffff;
	}

	.github-link:hover {
		background-color: #5c4eb3;
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(106, 90, 205, 0.5);
	}

	:root.theme-light .github-link:hover {
		background-color: #5c4eb3;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 1.5rem 0;
	}

	.content :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.back-link,
	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus,
	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.content :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
