---
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre mim | Iasmim Horrana" description="Sobre a experiência de Iasmim Horrana">
	<div class="stack gap-20">
		<main class="wrapper about">
			<div class="hero-container">
				<Hero
					title="Sobre mim"
					tagline="Obrigada por visitar. Leia abaixo para saber mais sobre minha trajetória profissional."
				/>
			</div>

			<section>
				<h2 class="section-title">Especialização</h2>
				<div class="content">
					<p>
						Atualmente focada em arquitetura de dados e engenharia de pipelines escaláveis.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Trabalhos</h2>
				<div class="content">
					<p>Experiência prática construindo soluções analíticas.</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Certificações</h2>
				<div class="content">
					<p>Em busca de aprendizado contínuo nas melhores ferramentas de Cloud e Big Data.</p>
				</div>
			</section>
		</main>
	</div>
</BaseLayout>

<style>
	.hero-container {
		padding-top: 5rem;
		margin-bottom: 2rem;
	}

	@media (min-width: 50em) {
		.hero-container {
			padding-top: 6rem;
			margin-bottom: 4rem;
		}
	}

	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
