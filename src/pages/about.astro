---
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre mim | Iasmim Horrana" description="Trajetória profissional de Iasmim Horrana, Engenheira de Dados Jr.">
	<div class="stack gap-20">
		<main class="wrapper about">
			<div class="hero-container">
				<Hero
					title="Sobre mim"
					tagline="Engenheira de Dados Jr. com experiência em pipelines, arquitetura Medalhão e ecossistema Databricks."
				/>
			</div>

			<!-- ── EDUCAÇÃO ───────────────────────────────────── -->
			<section>
				<h2 class="section-title">Educação</h2>
				<div class="content">
					<div class="edu-item">
						<div class="edu-top">
							<span class="edu-degree">Tecnologia em Ciência de Dados</span>
							<span class="edu-badge">Em andamento</span>
						</div>
						<span class="edu-school">UNINTER · conclusão jun/2026</span>
					</div>
				</div>
			</section>

			<!-- ── EXPERIÊNCIA ────────────────────────────────── -->
			<section>
				<h2 class="section-title">Experiência</h2>
				<div class="content">
					<div class="timeline">

						<div class="timeline-item">
							<div class="timeline-meta">
								<span class="timeline-period">Set 2025 — Mar 2026</span>
								<span class="timeline-location">Remoto · Salvador, BA</span>
							</div>
							<div class="timeline-body">
								<h3 class="timeline-role">Engenheira de Dados Jr. — Estágio</h3>
								<span class="timeline-company">Redrex</span>
								<ul class="timeline-list">
									<li>Pipelines de ingestão e transformação no Databricks, reduzindo o tempo de processamento em até 80%.</li>
									<li>Arquitetura Medalhão (Bronze, Silver, Gold) com rastreabilidade e governança ao longo do Data Lake.</li>
									<li>Integração de fontes em ambiente centralizado, viabilizando relatórios estratégicos para a liderança.</li>
									<li>Validações com Spark SQL para identificar e corrigir inconsistências antes da carga nas camadas superiores.</li>
								</ul>
							</div>
						</div>

						<div class="timeline-item">
							<div class="timeline-meta">
								<span class="timeline-period">Dez 2023 — Nov 2024</span>
								<span class="timeline-location">Salvador, BA</span>
							</div>
							<div class="timeline-body">
								<h3 class="timeline-role">Assistente de TI e Operações</h3>
								<span class="timeline-company">Itaparica Tour Operator</span>
								<ul class="timeline-list">
									<li>Suporte a sistemas de reservas, reduzindo tempo de inatividade operacional.</li>
									<li>Gestão de bases de dados de clientes com foco em integridade e consistência.</li>
									<li>Colaboração com equipes de operações, comercial e atendimento.</li>
								</ul>
							</div>
						</div>

					</div>
				</div>
			</section>

			<!-- ── FERRAMENTAS ────────────────────────────────── -->
			<section>
				<h2 class="section-title">Ferramentas</h2>
				<div class="content">
					<ul class="skills-list">
					<li><strong>Linguagens:</strong> Python (Pandas, PySpark) · SQL · Spark SQL</li>
					<li><strong>Big Data & Cloud:</strong> Databricks · Apache Spark · AWS (S3, EC2)</li>
					<li><strong>Orquestração & DevOps:</strong> Apache Airflow · Docker · dbt</li>
					<li><strong>Bancos de Dados:</strong> PostgreSQL · MySQL · SQL Server</li>
					<li><strong>Arquiteturas:</strong> Data Lake · MinIO · Medalhão (Bronze/Silver/Gold) · ETL/ELT</li>
					<li><strong>Visualização:</strong> Metabase</li>
					<li><strong>Idiomas:</strong> Inglês (B1)</li>
				</ul>
				</div>
			</section>

		</main>
	</div>
</BaseLayout>

<style>
	.hero-container {
		padding-top: 5rem;
		margin-bottom: 1rem;
	}

	@media (min-width: 50em) {
		.hero-container {
			padding-top: 6rem;
			margin-bottom: 2rem;
		}
	}

	/* ── Layout ───────────────────────────── */

	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
		padding-bottom: 5rem;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	@media (min-width: 50em) {
		section {
			display: grid;
			grid-template-columns: 180px 1fr;
			gap: 1.5rem 3rem;
			align-items: start;
		}
	}

	/* ── Section title ────────────────────── */

	.section-title {
		font-size: var(--text-base);
		color: var(--gray-300);
		font-family: var(--font-body);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding-top: 0.25rem;
	}

	/* ── Educação ─────────────────────────── */

	.edu-item {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
	}

	.edu-top {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.edu-degree {
		font-size: var(--text-base);
		color: var(--gray-100);
		font-weight: 600;
		font-family: var(--font-body);
	}

	.edu-badge {
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--accent-light);
		background-color: var(--accent-subtle-overlay);
		border: 1px solid var(--accent-overlay);
		padding: 0.15rem 0.55rem;
		border-radius: 999px;
	}

	.edu-school {
		font-size: var(--text-sm);
		color: var(--gray-400);
	}

	/* ── Timeline ─────────────────────────── */

	.timeline {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.5rem;
		padding-left: 1rem;
		border-left: 2px solid var(--accent-overlay);
	}

	@media (min-width: 50em) {
		.timeline-item {
			grid-template-columns: 130px 1fr;
			gap: 0 1.5rem;
			align-items: start;
		}
	}

	.timeline-meta {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding-top: 0.1rem;
	}

	.timeline-period {
		font-size: 0.8rem;
		color: var(--accent-light);
		font-weight: 500;
	}

	.timeline-location {
		font-size: 0.75rem;
		color: var(--gray-400);
	}

	.timeline-role {
		font-size: var(--text-base);
		color: var(--gray-0);
		font-weight: 600;
		font-family: var(--font-body);
		margin-bottom: 0.1rem;
	}

	.timeline-company {
		font-size: var(--text-sm);
		color: var(--gray-400);
		display: block;
		margin-bottom: 0.65rem;
	}

	.timeline-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.timeline-list li {
		font-size: var(--text-sm);
		color: var(--gray-200);
		line-height: 1.6;
		padding-left: 1rem;
		position: relative;
	}

	.timeline-list li::before {
		content: '–';
		position: absolute;
		left: 0;
		color: var(--accent-light);
	}

	/* ── Skills list ──────────────────────── */

	.skills-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		font-family: var(--font-body);
	}

	.skills-list li {
		font-size: var(--text-sm);
		color: var(--gray-200);
		line-height: 1.6;
	}

	.skills-list li strong {
		color: var(--gray-100);
		font-weight: 600;
	}
</style>
