---
import Icon from './Icon.astro';
---

<header class="top-header">
	<a href={import.meta.env.BASE_URL} class="logo">
		&lt;IasmimHorrana/&gt;
	</a>
	
	<theme-toggle>
		<button aria-label="Alterar Tema">
			<span class="icon light-icon"><Icon icon="sun" size="1.2em" /></span>
			<span class="icon dark-icon"><Icon icon="moon-stars" size="1.2em" /></span>
		</button>
	</theme-toggle>
</header>

<script>
	class ThemeToggle extends HTMLElement {
		constructor() {
			super();

			const button = this.querySelector('button')!;

			/** Set the theme to dark/light mode. */
			const setTheme = (dark: boolean) => {
				document.documentElement.classList[dark ? 'remove' : 'add']('theme-light');
				button.setAttribute('aria-pressed', String(dark));
				localStorage.setItem('theme', dark ? 'dark' : 'light');
			};

			// Initialize
			const isDark = !document.documentElement.classList.contains('theme-light');
			button.setAttribute('aria-pressed', String(isDark));

			// Toggle the theme when a user clicks the button.
			button.addEventListener('click', () => {
				const isDark = document.documentElement.classList.contains('theme-light');
				setTheme(isDark); // If it HAS theme-light, it means it's light, so switch to dark
			});
		}
	}
	customElements.define('theme-toggle', ThemeToggle);
</script>

<style>
	.top-header {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2rem;
		z-index: 10;
	}

	.logo {
		font-family: monospace;
		font-size: 1.25rem;
		font-weight: bold;
		color: var(--text-color);
		letter-spacing: -0.5px;
		text-decoration: none;
	}

	theme-toggle {
		display: flex;
	}

	button {
		display: flex;
		border: 0;
		border-radius: 999rem;
		padding: 0;
		background-color: transparent;
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.2);
		cursor: pointer;
		color: var(--text-color);
		overflow: hidden;
		position: relative;
	}

	:root.theme-light button {
		box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.2);
	}

	.icon {
		z-index: 1;
		position: relative;
		display: flex;
		padding: 0.5rem;
		width: 2.5rem;
		height: 2.5rem;
		justify-content: center;
		align-items: center;
		transition: color 0.2s ease;
	}

	/* Toggle state styles */
	button::before {
		content: '';
		position: absolute;
		inset: 0;
		background-color: var(--text-color);
		opacity: 0.1;
		border-radius: 999rem;
		transform: translateX(0);
		transition: transform 0.2s ease, width 0.2s ease;
		width: 50%;
	}

	button[aria-pressed="false"]::before {
		transform: translateX(100%);
	}

	/* Active icon colors */
	button[aria-pressed="true"] .dark-icon {
		color: var(--text-color);
	}
	button[aria-pressed="true"] .light-icon {
		color: rgba(255, 255, 255, 0.4);
	}
	:root.theme-light button[aria-pressed="true"] .light-icon {
		color: rgba(0, 0, 0, 0.4);
	}

	button[aria-pressed="false"] .light-icon {
		color: var(--text-color);
	}
	button[aria-pressed="false"] .dark-icon {
		color: rgba(0, 0, 0, 0.4);
	}
</style>
